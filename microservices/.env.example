MICROSERVICES_VERSION=1.0.0
AWS_ACCOUNT_ID=205474062795
AWS_REGION=eu-west-1
KUBERNETES_NAMESPACE=microservices
ENVIRONMENT=dev

# Database
DB_HOST=mysql
DB_USER=root
